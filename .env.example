# =========================================================
# Beim Produktiv-Deployment reichen die als (PFLICHT) markierten
# Werte. Alle anderen Einstellungen werden beim ersten Aufruf
# durch den webbasierten Setup-Wizard erfasst und verschlüsselt
# in der DB persistiert.
#
# ENV-Variablen haben IMMER Vorrang vor DB-Werten — wer Secrets
# per Vault/Doppler injiziert, kann die entsprechenden Felder
# hier setzen und der Wizard überspringt sie automatisch.
# =========================================================

# ===== App =====
NODE_ENV=development
APP_URL=http://localhost:3000                  # (PFLICHT)

# ===== Auth (NextAuth) =====
NEXTAUTH_URL=http://localhost:3000             # (PFLICHT)
# generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me                      # (PFLICHT) — wird auch als Master-Key für Setting-Verschlüsselung genutzt

# ===== Database =====
DATABASE_URL=postgresql://merchshop:merchshop@localhost:5432/merchshop?schema=public   # (PFLICHT)

# ===== Object Storage (MinIO / S3) =====
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=merchshop-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ===== E-Mail =====
# Option A: Resend
RESEND_API_KEY=
# E-Mail-Absender — lokal setzen, nicht ins Repo committen
MAIL_FROM=

# Option B: SMTP (alternativ)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ===== Versand: DHL Geschäftskundenversand =====
DHL_API_KEY=
DHL_USER=
DHL_PASSWORD=
DHL_ACCOUNT_NUMBER=
DHL_ENVIRONMENT=sandbox    # sandbox | production

# ===== Monitoring (optional) =====
SENTRY_DSN=


# ===== Background-Jobs =====
# Schützt die /api/jobs/* Endpunkte, sodass nur dein Cron sie aufrufen kann.
# Generieren mit: openssl rand -hex 24
JOBS_TOKEN=

# ===== Feature Flags =====
FEATURE_2FA_ENABLED=false
FEATURE_MAGIC_LINK_ENABLED=false

# ===== Setup-Wizard =====
# Erlaubt Re-Initialisierung des Wizards nach erfolgter Installation.
# In Produktion auf "false" lassen!
ALLOW_SETUP_REINIT=false
